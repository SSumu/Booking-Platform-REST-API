# ==========================
# Server
# ==========================
PORT=3000

# ==========================
# Database
# Choose "postgres" (preferred / used for the committed migrations)
# or "sqlite" (zero-install option for a quick local trial run).
# ==========================
DB_TYPE=postgres

# Used when DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=root
DB_NAME=booking_platform

# Used when DB_TYPE=sqlite
SQLITE_DB_PATH=database.sqlite

DB_LOGGING=false

# ==========================
# JWT
# ==========================
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN=7d
